# Database Configuration
MONGO_URI=mongodb://localhost:27017/chatbot
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10
# MONGO_WAIT_QUEUE_TIMEOUT=10000
# MONGO_SERVER_SELECTION_TIMEOUT=5000

# Google APIs Configuration
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CSE_ID=your-google-cse-id-here
# Get these from: https://console.cloud.google.com/

# Frontend & CORS Configuration
# Comma-separated list of allowed origin URLs (no spaces after commas)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
# For production, update to your domain: https://yourdomain.com

# Authentication & Security
JWT_SECRET=your-jwt-secret-key-here-minimum-32-characters-long
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Change this in production to a strong random string

SESSION_SECRET=your-session-secret-key-here-minimum-32-characters-long
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Used by express-session for secure cookie signing

# Session Configuration
# SESSION_MAX_AGE=604800000      # 1 week in milliseconds (default)
# SESSION_SECURE=false           # Set to 'true' in production with HTTPS
# SESSION_SAME_SITE=lax          # CSRF protection: 'lax' or 'strict'

# LLM Configuration
# LLM_MODEL=gemini-2.5-flash    # Default model name
# LLM_TEMPERATURE=0             # 0 for deterministic, higher for creative
# LLM_MAX_TOKENS=2000           # Maximum tokens in response

# RAG Configuration
# RETRIEVAL_TOP_K=3             # Number of chunks to retrieve (default)
# CHUNK_SIZE=1000               # Characters per chunk
# CHUNK_OVERLAP=200             # Overlap between chunks

# Cache Configuration
# VIDEO_CACHE_TTL=3600          # Video cache lifetime (seconds, 1 hour)
# SESSION_CACHE_TTL=86400        # Session cache lifetime (seconds, 24 hours)
# MAX_CHAT_HISTORY=50           # Max messages per session

# Feature Flags
# ENABLE_WEB_SEARCH=true        # Enable web search capability
# ENABLE_TRANSLATION=true       # Enable translation feature
# ENABLE_SUMMARIZATION=true     # Enable summarization feature

# Query Validation
# QUERY_MAX_LENGTH=5000         # Max query length (Pydantic validation)
# QUERY_MIN_LENGTH=1            # Min query length
# ORCHESTRATOR_QUERY_MAX_LENGTH=1000  # Max length before LLM orchestrator

# Logging
# LOG_LEVEL=INFO                # debug, info, warn, error
# LOG_FORMAT=default            # Custom format if needed

# Optional: Perplexity API (if using web search)
# PPLX_API_KEY=your-perplexity-api-key-here
