# ============================================================
# YouTube Chatbot - Environment Variables Configuration
# ============================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to git (it contains secrets)
# ============================================================

# ============================================================
# MONGODB DATABASE CONFIGURATION
# ============================================================
# Connection string for MongoDB instance
# Local dev: mongodb://localhost:27017/chatbot
# Docker Compose: mongodb://mongodb:27017/chatbot
# Production: mongodb+srv://user:pass@cluster.mongodb.net/chatbot
MONGO_URI=mongodb://localhost:27017/chatbot

# MongoDB Connection Pool Settings (already tuned in code)
MONGO_MAX_POOL_SIZE=50
MONGO_MIN_POOL_SIZE=10

# ============================================================
# GOOGLE APIs CONFIGURATION
# ============================================================
# Gemini AI API Key - Get from: https://ai.google.dev
# Used for: LLM inference, structured output generation
GOOGLE_API_KEY=AIzaSy_YOUR_GEMINI_API_KEY_HERE

# Google Custom Search API Key - Get from: https://console.developers.google.com
# Used for: Optional web search in RAG pipeline
GOOGLE_SEARCH_KEY=AIzaSy_YOUR_CUSTOM_SEARCH_KEY_HERE

# Google Custom Search Engine ID - Create at: https://cse.google.com
# Used with GOOGLE_SEARCH_KEY for web search functionality
GOOGLE_CSE_ID=your-custom-search-engine-id

# ============================================================
# AUTHENTICATION & SESSION CONFIGURATION
# ============================================================
# JWT Secret for token signing (MINIMUM 32 characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-jwt-secret-minimum-32-characters-required

# Session Secret for express-session (MINIMUM 32 characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=your-session-secret-minimum-32-characters-required

# Session max age in milliseconds (default: 1 week = 604800000)
SESSION_MAX_AGE=604800000

# Set to 'true' in production (requires HTTPS)
SESSION_SECURE=false

# Session same-site policy: 'strict', 'lax', or 'none'
SESSION_SAME_SITE=lax

# ============================================================
# CORS CONFIGURATION
# ============================================================
# Comma-separated list of allowed origins (no spaces after commas)
# Local dev: http://localhost:5173,http://localhost:5174,http://localhost:5175
# Docker Compose: http://localhost:5173,http://frontend:80
# Production: https://yourdomain.com,https://app.yourdomain.com
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ============================================================
# SERVICE URLs (For containerized environments)
# ============================================================
# FastAPI/Chatbot service URL (used by Express backend)
# Local development: http://localhost:8080
# Docker Compose: http://chatbot:8080 (service name resolution)
# Kubernetes: http://chatbot-service:8080
FASTAPI_URL=http://localhost:8080

# ============================================================
# SERVER PORTS (Can be overridden by PORT environment variable)
# ============================================================
# PORT=8000        # FastAPI port (or set in docker-compose)
# PORT=5000        # Express backend port

# ============================================================
# LOGGING CONFIGURATION
# ============================================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ============================================================
# LLM CONFIGURATION (Optional - defaults in code)
# ============================================================
# LLM_MODEL=gemini-2.5-flash
# LLM_TEMPERATURE=0
# LLM_MAX_TOKENS=2000

# ============================================================
# RAG CONFIGURATION (Optional - defaults in code)
# ============================================================
# RETRIEVAL_TOP_K=3
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=200

# ============================================================
# CACHE CONFIGURATION (Optional - defaults in code)
# ============================================================
# VIDEO_CACHE_TTL=3600
# SESSION_CACHE_TTL=86400
# MAX_CHAT_HISTORY=50

# ============================================================
# IMPORTANT NOTES FOR CONTAINERIZATION
# ============================================================
# Docker Compose:
#   - Replace localhost with service names (e.g., mongodb, chatbot, backend)
#   - Example: MONGO_URI=mongodb://mongodb:27017/chatbot
#   - Example: FASTAPI_URL=http://chatbot:8080
#
# Kubernetes:
#   - Use DNS service names
#   - Example: mongodb://mongodb-service.yt-chatbot.svc.cluster.local:27017
#   - Example: http://chatbot-service.yt-chatbot.svc.cluster.local:8080
#
# GitHub Actions / CI/CD:
#   - Store secrets in repository settings (Settings > Secrets)
#   - Reference as: ${{ secrets.GOOGLE_API_KEY }}
#   - DO NOT commit .env files to repository
#
# Production:
#   - Use external secrets management (Vault, AWS Secrets Manager, etc.)
#   - Set HTTPS_ONLY=true, SESSION_SECURE=true
#   - Use strong, randomly generated secrets (not words)
