# RAG Configuration
# RETRIEVAL_TOP_K=3             # Number of chunks to retrieve (default)
# CHUNK_SIZE=1000               # Characters per chunk
# CHUNK_OVERLAP=200             # Overlap between chunks

# Cache Configuration
