# Database Configuration
MONGO_URI=mongodb://localhost:27017/chatbot
# Connection pooling: maxPoolSize=50, minPoolSize=10, waitQueueTimeoutMS=10000, serverSelectionTimeoutMS=5000

# Google APIs Configuration
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_CSE_ID=your-google-cse-id-here
# Get these from: https://console.cloud.google.com/

# Frontend & CORS Configuration
# Comma-separated list of allowed origin URLs (no spaces after commas)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175
# For production, update to your domain: https://yourdomain.com

# Authentication & Security
JWT_SECRET=your-jwt-secret-key-here-minimum-32-characters-long
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# IMPORTANT: Change this in production to a strong random string

SESSION_SECRET=your-session-secret-key-here-minimum-32-characters-long
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Used by express-session for secure cookie signing

# Optional: Perplexity API (if using web search)
# PPLX_API_KEY=your-perplexity-api-key-here

# RAG Configuration (Optional)
# RETRIEVAL_TOP_K=3
# CHUNK_SIZE=1000
# CHUNK_OVERLAP=100

# Environment
# NODE_ENV=production  # Change to 'production' for production deployments
# LOG_LEVEL=info      # debug, info, warn, error

# ============================================
# REQUIRED VARIABLES (Application will crash without these):
# - MONGO_URI
# - GOOGLE_API_KEY
# - GOOGLE_CSE_ID
# - CORS_ORIGINS
# - JWT_SECRET (minimum 32 characters)
# - SESSION_SECRET (minimum 32 characters)
#
# OPTIONAL VARIABLES (Have sensible defaults if not set):
# - PPLX_API_KEY (only if using web search feature)
# - RETRIEVAL_TOP_K (default: 3)
# - CHUNK_SIZE (default: 1000)
# - CHUNK_OVERLAP (default: 100)
#
# ENVIRONMENT HINTS:
# - Development: CORS_ORIGINS=http://localhost:5173,...
# - Production: CORS_ORIGINS=https://yourdomain.com
# - JWT_SECRET and SESSION_SECRET must be strong, random strings (32+ chars)
# - Never commit actual .env file with real credentials to version control
# ============================================
